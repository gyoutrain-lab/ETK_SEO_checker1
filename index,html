    <!-- INTERACTIVE SCRIPTS CODE -->
    <script>
        // Tab-Switching Logic for Vertical Dashboard
        function switchTab(evt, tabId) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName("tab-panel");
            for (i = 0; i < tabcontent.length; i++) {
                tabcontent[i].className = tabcontent[i].className.replace(" active", "");
            }
            tablinks = document.getElementsByClassName("tab-btn");
            for (i = 0; i < tablinks.length; i++) {
                tablinks[i].className = tablinks[i].className.replace(" active", "");
            }
            document.getElementById(tabId).className += " active";
            evt.currentTarget.className += " active";
        }

        // WhatsApp Secure Integration System
        function sendToWhatsApp(event, type) {
            event.preventDefault();
            var phoneNumber = "6281901685253";
            var message = "";
            
            if (type === 'Placement Test') {
                var name = document.getElementById('pt-name').value;
                var company = document.getElementById('pt-company').value;
                var program = document.getElementById('pt-program').value;
                message = "*Pengajuan Simulasi Uji Penempatan ETK*\n\n" +
                          "*Nama:* " + name + "\n" +
                          "*Instansi:* " + company + "\n" +
                          "*Program:* " + program;
            } else if (type === 'Registrasi Anggota Baru') {
                var regName = document.getElementById('reg-name').value;
                var regPhone = document.getElementById('reg-phone').value;
                message = "*Registrasi Resmi Anggota Baru ETK*\n\n" +
                          "*Nama Lengkap:* " + regName + "\n" +
                          "*Telepon:* " + regPhone;
            }
            
            var url = "https://api.whatsapp.com/send?phone=" + phoneNumber + "&text=" + encodeURIComponent(message);
            window.open(url, '_blank');
        }
    </script>
