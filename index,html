            .problem-banner-text { font-size: 13px; line-height: 1.4; padding: 0 10px; }
            .problem-banner-text .gold-trigger { font-size: 15px; display: block; margin: 4px auto 0 auto; }
            nav { justify-content: center; flex-wrap: wrap; gap: 10px; }
            nav a { margin: 0 8px; font-size: 14px; }
            .hero-text-side h1 { font-size: 30px; }
            .article-wrapper { padding: 35px 25px; }
            .section-title { font-size: 28px; }
        }
    </style>
</head>
