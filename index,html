        /* RESPONSIVE LAYOUT MECHANICS */
        @media (max-width: 1120px) {
            .logo-solution-wrapper { min-width: 380px; }
            .logo { width: 100px; }
            .logo img { height: 100px; top: -50px; }
            .solution-text { font-size: 13px; }
            nav a { font-size: 16px; margin-left: 18px; }
            .problem-banner-text { font-size: 16px; }
